{
  "manifest_version": 3,
  "name": "EZK-PM Enterprise Autofill",
  "version": "1.0.0",
  "key": "",
  "description": "Zero-Knowledge Autofill Bridge (FA 21 & FA 22)",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon_gray.png",
    "48": "icons/icon_gray.png",
    "128": "icons/icon_gray.png"
  },
  "action": {
    "default_icon": "icons/icon_gray.png",
    "default_title": "EZKPM Native Bridge",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "content.js" ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [ "icons/icon_green.png" ],
      "matches": [ "<all_urls>" ]
    }
  ]
}