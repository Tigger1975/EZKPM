<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:contracts="clr-namespace:EZKPM.Shared.Contracts;assembly=EZKPM.Shared.Contracts"
        xmlns:local="clr-namespace:EZKPM.Client.Desktop"
        xmlns:res="using:EZKPM.Client.Desktop.Resources"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Inter, sans-serif"
        x:Class="EZKPM.Client.Desktop.MainWindow"
        Title="EZKPM Vault Manager"
        Icon="avares://EZKPM.Client.Desktop/Assets/logo.png"
        Background="#F5F7FA">
    <Window.Resources>
        <local:AssetTypeToIconConverter x:Key="IconConverter" />
        <local:StringTruncateConverter x:Key="TruncateConverter" />
    </Window.Resources>
    
    <Window.Styles>
        <!-- Sleek TextBoxes -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <!-- Elegant Buttons -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.success:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4B5563"/>
        </Style>
        <Style Selector="Button.outline:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <!-- Labels -->
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Button.autotype">
            <Setter Property="Background" Value="#FACC15"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
        <Style Selector="Button.autotype:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EAB308"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <!-- DataGrid Styles -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SeparatorBrush" Value="Transparent"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="MinHeight" Value="45"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="320, *">
        <!-- Sidebar: Asset List (Dark Theme) -->
        <ThemeVariantScope Grid.Column="0" RequestedThemeVariant="Dark">
        <Border Background="#1E293B" BorderThickness="0,0,1,0" BorderBrush="#0F172A">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="EZKPM" FontWeight="Black" FontSize="24" Foreground="White" LetterSpacing="1"/>
                    <TextBlock Text="Enterprise Vault" FontSize="12" Foreground="#94A3B8"/>
                    <Button Classes="outline" Content="🔄 Rotation Assistant" Margin="0,15,0,0" Click="OpenRotationAssistant_Click" Foreground="#94A3B8" BorderBrush="#374151" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button x:Name="AdminPanelButton" Classes="outline" Content="🛡️ Admin &amp; Recovery" Margin="0,10,0,0" Click="OpenAdminPanel_Click" Foreground="#FACC15" BorderBrush="#374151" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsVisible="False"/>
                </StackPanel>
                
                <TreeView x:Name="AssetTreeView" Grid.Row="1" Background="Transparent" 
                          SelectionChanged="AssetTreeView_SelectionChanged"
                          DragDrop.AllowDrop="True"
                          DragDrop.DragOver="AssetTreeView_DragOver"
                          DragDrop.Drop="AssetTreeView_Drop">
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem" x:DataType="local:VaultTreeNode">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                        <!-- Custom selected/hover colors for the dark blue background -->
                        <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot:pointerover">
                            <Setter Property="Background" Value="#374151" />
                        </Style>
                        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
                            <Setter Property="Background" Value="#4B5563" />
                        </Style>
                    </TreeView.Styles>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="local:VaultTreeNode" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4" Background="Transparent"
                                        PointerPressed="TreeNode_PointerPressed"
                                        PointerMoved="TreeNode_PointerMoved">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{x:Static res:AppStrings.Main_MenuEditFolder}" Click="EditFolderMenuItem_Click" />
                                        <MenuItem Header="{x:Static res:AppStrings.Main_MenuDeleteFolder}" Click="DeleteFolderMenuItem_Click" Foreground="#EF4444" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="18" VerticalAlignment="Center" Foreground="#FACC15"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Medium" Foreground="White" FontSize="14" />
                                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="#94A3B8" IsVisible="{Binding HasUrl}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
                
                <Grid Grid.Row="2" ColumnDefinitions="*, *, Auto, Auto" Margin="0,20,0,0">
                    <Button Grid.Column="0" Classes="success" Content="{x:Static res:AppStrings.Main_BtnNewAsset}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" Click="NewAssetButton_Click"/>
                    <Button Grid.Column="1" Classes="outline" Content="{x:Static res:AppStrings.Main_BtnNewFolder}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,5,0" Click="NewFolderButton_Click"/>
                    <Button Grid.Column="2" Classes="outline" Content="❓" ToolTip.Tip="Hilfe / Wiki" Click="OpenHelp_Click" Margin="0,0,5,0" />
                    <Button Grid.Column="3" Classes="outline" Content="⚙️" ToolTip.Tip="{x:Static res:AppStrings.Main_MenuSettings}">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{x:Static res:AppStrings.Main_MenuSettings}" Click="ChangeServerMenuItem_Click" />
                                <MenuItem Header="Sicherheit &amp; Notfall-Wiederherstellung" Click="OpenSecuritySettings_Click" />
                                <MenuItem Header="{x:Static res:AppStrings.Settings_CheckUpdate}" Click="CheckForUpdates_Click" />
                                <MenuItem Header="{x:Static res:AppStrings.Settings_About}" Click="ShowVersion_Click" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Grid>
        </Border>
        </ThemeVariantScope>

        <!-- Main Area -->
        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Margin="30">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentFolderTitle" Text="All Items" FontSize="26" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock x:Name="CurrentFolderItemCount" Text="0 items" FontSize="14" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBox x:Name="SearchTextBox" PlaceholderText="🔍 Search Passwords..." Width="220" TextChanged="SearchTextBox_TextChanged" CornerRadius="20" Background="White" BorderBrush="#E5E7EB"/>
                    
                    <Button Content="..." Classes="outline" ToolTip.Tip="Weitere Aktionen" CornerRadius="20" Width="36" HorizontalContentAlignment="Center">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Filter: Alle Typen" x:Name="MenuFilterAll" Click="MenuFilter_Click" Tag="All" />
                                <MenuItem Header="Filter: Login" Click="MenuFilter_Click" Tag="Login" />
                                <MenuItem Header="Filter: Payment" Click="MenuFilter_Click" Tag="Payment" />
                                <MenuItem Header="Filter: Passkey" Click="MenuFilter_Click" Tag="Passkey" />
                                <MenuItem Header="Filter: SecureNote" Click="MenuFilter_Click" Tag="SecureNote" />
                                <MenuItem Header="Filter: Papierkorb" Click="MenuFilter_Click" Tag="Trash" />
                                <MenuItem Header="Filter: Abgelaufen" Click="MenuFilter_Click" Tag="Expired" />
                                <Separator />
                                <MenuItem Header="{x:Static res:AppStrings.Main_BtnImport}" Click="ImportKeePass_Click" />
                                <MenuItem Header="{x:Static res:AppStrings.Main_BtnClean}" Click="CleanOrphans_Click" />
                                <MenuItem x:Name="MenuRestoreAssets" Header="{x:Static res:AppStrings.Main_BtnRestore}" Click="RestoreSelectedAssets_Click" IsVisible="False" Foreground="#10B981" />
                                <MenuItem Header="{x:Static res:AppStrings.Main_BtnDelete}" Click="DeleteSelectedAssets_Click" Foreground="#EF4444" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- DataGrid -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True">
                <DataGrid x:Name="AssetsDataGrid" x:DataType="contracts:VaultAssetPayload" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6" DoubleTapped="AssetsDataGrid_DoubleTapped" Background="White" SelectionMode="Extended" CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Type" Width="70" SortMemberPath="AssetType">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="contracts:VaultAssetPayload">
                                    <TextBlock Text="{Binding AssetType, Converter={StaticResource IconConverter}}" FontFamily="Segoe UI Emoji" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Name" Width="2*" SortMemberPath="Title">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="contracts:VaultAssetPayload">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="5,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#111827" />
                                        <Border Background="#EF4444" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" IsVisible="{Binding IsExpired}">
                                            <TextBlock Text="{x:Static res:AppStrings.Main_LblExpired}" Foreground="White" FontSize="10" FontWeight="Bold" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="2*" Foreground="#4B5563" />

                        <DataGridTemplateColumn Header="Description" Width="2*" SortMemberPath="DetailedDescription">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="contracts:VaultAssetPayload">
                                    <TextBlock Text="{Binding DetailedDescription}" MaxLines="1" TextTrimming="CharacterEllipsis" Margin="5" VerticalAlignment="Center" Foreground="#4B5563" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Auto-Type" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="contracts:VaultAssetPayload">
                                    <Button Content="Auto-Type" Classes="autotype" Margin="10,5" Click="DataGridAutoType_Click" Tag="{Binding}" IsVisible="{Binding HasAutoTypeConfigured}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Status Message -->
            <SelectableTextBlock Grid.Row="2" x:Name="StatusTextBlock" Text="" Foreground="#6B7280" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
