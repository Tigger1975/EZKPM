<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:contracts="clr-namespace:EZKPM.Shared.Contracts;assembly=EZKPM.Shared.Contracts"
        xmlns:local="clr-namespace:EZKPM.Client.Desktop"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Inter, sans-serif"
        x:Class="EZKPM.Client.Desktop.MainWindow"
        Title="EZKPM Vault Manager"
        Background="#F5F7FA">
    <Window.Resources>
        <local:AssetTypeToIconConverter x:Key="IconConverter" />
        <local:StringTruncateConverter x:Key="TruncateConverter" />
    </Window.Resources>
    
    <Window.Styles>
        <!-- Sleek TextBoxes -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <!-- Elegant Buttons -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.success:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4B5563"/>
        </Style>
        <Style Selector="Button.outline:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <!-- Labels -->
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="320, *">
        <!-- Sidebar: Asset List (Dark Theme) -->
        <ThemeVariantScope Grid.Column="0" RequestedThemeVariant="Dark">
        <Border Background="#1E293B" BorderThickness="0,0,1,0" BorderBrush="#0F172A">
            <Grid RowDefinitions="Auto, *, Auto" Margin="20">
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="EZKPM" FontWeight="Black" FontSize="24" Foreground="White" LetterSpacing="1"/>
                    <TextBlock Text="Enterprise Vault" FontSize="12" Foreground="#94A3B8"/>
                </StackPanel>
                
                <TreeView x:Name="AssetTreeView" Grid.Row="1" Background="Transparent" 
                          SelectionChanged="AssetTreeView_SelectionChanged"
                          DragDrop.AllowDrop="True"
                          DragDrop.DragOver="AssetTreeView_DragOver"
                          DragDrop.Drop="AssetTreeView_Drop">
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem" x:DataType="local:VaultTreeNode">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                        <!-- Custom selected/hover colors for the dark blue background -->
                        <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot:pointerover">
                            <Setter Property="Background" Value="#374151" />
                        </Style>
                        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
                            <Setter Property="Background" Value="#4B5563" />
                        </Style>
                    </TreeView.Styles>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="local:VaultTreeNode" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4" Background="Transparent"
                                        PointerPressed="TreeNode_PointerPressed"
                                        PointerMoved="TreeNode_PointerMoved">
                                <TextBlock Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center" Foreground="#FACC15"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Medium" Foreground="White" FontSize="14" />
                                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="#94A3B8" IsVisible="{Binding HasUrl}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
                
                <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,20,0,0">
                    <Button Grid.Column="0" Classes="success" Content="+ Asset" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" Click="NewAssetButton_Click"/>
                    <Button Grid.Column="1" Classes="outline" Content="+ Folder" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" Click="NewFolderButton_Click"/>
                </Grid>
            </Grid>
        </Border>
        </ThemeVariantScope>

        <!-- Main Area -->
        <Grid Grid.Column="1" RowDefinitions="*, Auto">
            <TabControl Grid.Row="0" x:Name="MainTabControl" Margin="10">
                <TabItem Header="🗂️ Assets" x:Name="AssetListTab">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Toolbar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" Spacing="10">
                            <TextBox x:Name="SearchTextBox" PlaceholderText="Suchen..." Width="250" TextChanged="SearchTextBox_TextChanged" />
                            <ComboBox x:Name="TypeFilterComboBox" Width="150" SelectedIndex="0" SelectionChanged="TypeFilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Alle Typen" />
                                <ComboBoxItem Content="Login" />
                                <ComboBoxItem Content="Passkey" />
                                <ComboBoxItem Content="Payment" />
                                <ComboBoxItem Content="SecureNote" />
                                <ComboBoxItem Content="SSH Key" />
                                <ComboBoxItem Content="SSL Key" />
                                <ComboBoxItem Content="API Key" />
                                <ComboBoxItem Content="Authenticator" />
                            </ComboBox>
                            <Button Content="🗑️ Löschen" Classes="outline" Click="DeleteSelectedAssets_Click" Foreground="#EF4444" BorderBrush="#EF4444" />
                        </StackPanel>

                        <DataGrid Grid.Row="1" x:Name="AssetsDataGrid" x:DataType="contracts:VaultAssetPayload" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="#E5E7EB" DoubleTapped="AssetsDataGrid_DoubleTapped" Background="White" SelectionMode="Extended" CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Typ" Width="60" SortMemberPath="AssetType">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="contracts:VaultAssetPayload">
                                            <TextBlock Text="{Binding AssetType, Converter={StaticResource IconConverter}}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Name" Binding="{Binding Title}" Width="2*" />

                                <DataGridTemplateColumn Header="Beschreibung" Width="3*" SortMemberPath="DetailedDescription">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="contracts:VaultAssetPayload">
                                            <TextBlock Text="{Binding DetailedDescription}" TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis" Margin="5" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="URL" Width="2*" SortMemberPath="Url">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="contracts:VaultAssetPayload">
                                            <TextBlock Text="{Binding Url, Converter={StaticResource TruncateConverter}}" VerticalAlignment="Center" Margin="5" Foreground="#3B82F6" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Status Message pinned to bottom -->
            <Border Grid.Row="1" Background="White" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB" Padding="20,10">
                <SelectableTextBlock x:Name="StatusTextBlock" Text="" Foreground="#4B5563" FontSize="13" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
