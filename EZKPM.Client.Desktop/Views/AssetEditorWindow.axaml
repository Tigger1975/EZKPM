<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:contracts="clr-namespace:EZKPM.Shared.Contracts;assembly=EZKPM.Shared.Contracts"
        xmlns:local="clr-namespace:EZKPM.Client.Desktop.Views"
        xmlns:res="using:EZKPM.Client.Desktop.Resources"
        x:Class="EZKPM.Client.Desktop.Views.AssetEditorWindow"
        Title="Asset Editor" Width="900" Height="750"
        FontFamily="Inter, sans-serif, Segoe UI Emoji, Apple Color Emoji, Noto Color Emoji, Segoe UI Symbol"
        Background="White" WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#2563EB"/>
        </Style>
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4B5563"/>
        </Style>
        <Style Selector="Button.outline:pointerover">
            <Setter Property="Background" Value="#F3F4F6"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Styles>
    <ScrollViewer x:Name="EditorScrollViewer">
                            <StackPanel Spacing="12" x:Name="EditorPanel" IsVisible="True" Margin="40,20,40,40" MaxWidth="800" HorizontalAlignment="Left">
                                
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto, Auto" Margin="0,0,0,20">
                                    <TextBlock Grid.Column="0" Text="{x:Static res:AppStrings.AssetEditor_TitleDetails}" FontSize="28" FontWeight="Light" Foreground="#111827" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="outline" Content="🗗" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_PopOut}" Click="PopOutButton_Click" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="2" Classes="outline" Content="📄" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_Duplicate}" Click="DuplicateButton_Click" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="3" Classes="primary" Content="💾 ➕" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_SaveNew}" Click="SaveAndNewButton_Click" VerticalAlignment="Center" MinWidth="50" HorizontalContentAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="4" Classes="primary" Content="💾 ❌" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_SaveClose}" Click="SaveAndCloseButton_Click" VerticalAlignment="Center" MinWidth="50" HorizontalContentAlignment="Center"/>
                                </Grid>
                                
                                <TextBlock x:Name="StatusTextBlock" IsVisible="False" FontWeight="Bold" Margin="0,0,0,10" />

                                <Border x:Name="ExpiredWarningPanel" IsVisible="False" Background="#FEE2E2" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="⚠️" FontSize="24" VerticalAlignment="Center" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Static res:AppStrings.AssetEditor_ExpiredWarningTitle}" FontWeight="Bold" Foreground="#991B1B" FontSize="14" />
                                            <TextBlock Text="{x:Static res:AppStrings.AssetEditor_ExpiredWarningDesc}" Foreground="#7F1D1D" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                    <!-- Title, Type & Parent Folder -->
                    <Grid ColumnDefinitions="*, 20, 150, 20, 200">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblTitle}"/>
                            <TextBox x:Name="TitleTextBox" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhTitle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblType}"/>
                            <ComboBox x:Name="AssetTypeComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" CornerRadius="6" SelectionChanged="AssetTypeComboBox_SelectionChanged">
                                <ComboBoxItem>Login</ComboBoxItem>
                                <ComboBoxItem>Passkey</ComboBoxItem>
                                <ComboBoxItem>Payment</ComboBoxItem>
                                <ComboBoxItem>SecureNote</ComboBoxItem>
                                <ComboBoxItem>SSH Key</ComboBoxItem>
                                <ComboBoxItem>SSL Key</ComboBoxItem>
                                <ComboBoxItem>API Key</ComboBoxItem>
                                <ComboBoxItem>Authenticator</ComboBoxItem>
                                <ComboBoxItem>Folder</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblParent}"/>
                            <ComboBox x:Name="ParentFolderComboBox" HorizontalAlignment="Stretch" CornerRadius="6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:FolderSelectionItem">
                                        <TextBlock Text="{Binding DisplayTitle}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Credentials (Hidden for Folders) -->
                    <StackPanel x:Name="CredentialsPanel" Spacing="12">
                        <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,10" BoxShadow="0 2 4 0 #0A000000">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblUsername}"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox x:Name="UsernameTextBox" Grid.Column="0" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhUsername}"/>
                                <Button Grid.Column="1" Classes="outline" Content="📋" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipCopy}" Margin="10,0,0,0" Click="CopyUsernameButton_Click"/>
                            </Grid>

                            <TextBlock x:Name="PasswordLabel" Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblPassword}"/>
                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <TextBox x:Name="PasswordTextBox" Grid.Column="0" PasswordChar="•" PlaceholderText="••••••••" />
                                <Button Grid.Column="1" Classes="outline" Content="📋" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipCopy}" Margin="10,0,0,0" Click="CopyPasswordButton_Click"/>
                                <Button Grid.Column="2" Classes="outline" Content="🎲" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipGenerate}" Margin="10,0,0,0" Click="GeneratePasswordButton_Click"/>
                            </Grid>
                            <CheckBox x:Name="ShowPasswordCheckBox" Content="{x:Static res:AppStrings.AssetEditor_ShowPassword}" IsCheckedChanged="ShowPasswordCheckBox_CheckedChanged" Foreground="#4B5563"/>
                            
                            <!-- Payment Specific Fields -->
                            <StackPanel x:Name="PaymentPanel" IsVisible="True" Spacing="12">
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblPaymentMethod}"/>
                                <ComboBox x:Name="PaymentSubTypeComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" CornerRadius="4" SelectionChanged="PaymentSubTypeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_PayCard}" />
                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_PayService}" />
                                </ComboBox>

                                <StackPanel x:Name="CardDetailsPanel" Spacing="12">
                                    <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblCardHolder}"/>
                                    <TextBox x:Name="CardHolderTextBox" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhCardHolder}"/>
                                    
                                    <Grid ColumnDefinitions="*, 15, *">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblExpiry}"/>
                                            <TextBox x:Name="CardExpiryTextBox" PlaceholderText="12/26"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblCvc}"/>
                                            <TextBox x:Name="CardCvcTextBox" PlaceholderText="123" PasswordChar="•"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!-- File Upload Specific Fields (SSH, SSL, Passkey Containers) -->
                            <StackPanel x:Name="FileUploadPanel" IsVisible="True" Spacing="12">
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblPrimaryFile}"/>
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                    <TextBox x:Name="FileNameTextBox" Grid.Column="0" IsReadOnly="True" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhNoFile}" />
                                    <Button Grid.Column="1" Classes="outline" Content="📂" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipBrowse}" Margin="10,0,0,0" Click="BrowseFileButton_Click"/>
                                    <Button Grid.Column="2" Classes="outline" Content="🗑️" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipClear}" Margin="10,0,0,0" Click="ClearFileButton_Click"/>
                                    <Button x:Name="DownloadFileButton" Grid.Column="3" Classes="outline" Content="📥" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipDownload}" Margin="10,0,0,0" Click="DownloadFileButton_Click" IsVisible="True"/>
                                </Grid>
                                
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblSecondaryFile}"/>
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                    <TextBox x:Name="FileName2TextBox" Grid.Column="0" IsReadOnly="True" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhNoFile}" />
                                    <Button Grid.Column="1" Classes="outline" Content="📂" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipBrowse}" Margin="10,0,0,0" Click="BrowseFile2Button_Click"/>
                                    <Button Grid.Column="2" Classes="outline" Content="🗑️" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipClear}" Margin="10,0,0,0" Click="ClearFile2Button_Click"/>
                                    <Button x:Name="DownloadFile2Button" Grid.Column="3" Classes="outline" Content="📥" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipDownload}" Margin="10,0,0,0" Click="DownloadFile2Button_Click" IsVisible="True"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Expander Header="{x:Static res:AppStrings.AssetEditor_HdrGenerator}" HorizontalAlignment="Stretch" CornerRadius="8" Background="White" BorderBrush="#E5E7EB">
                        <StackPanel Spacing="10" Margin="10">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{x:Static res:AppStrings.AssetEditor_LblLength}" VerticalAlignment="Center" Foreground="#4B5563"/>
                                <NumericUpDown x:Name="GenLengthControl" Grid.Column="1" Value="20" Minimum="8" Maximum="128" Width="120" CornerRadius="4"/>
                            </Grid>
                            <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox x:Name="GenUpperCheck" Content="{x:Static res:AppStrings.AssetEditor_ChkUpper}" IsChecked="True" Margin="0,0,20,0" Foreground="#4B5563"/>
                                <CheckBox x:Name="GenLowerCheck" Content="{x:Static res:AppStrings.AssetEditor_ChkLower}" IsChecked="True" Margin="0,0,20,0" Foreground="#4B5563"/>
                                <CheckBox x:Name="GenNumberCheck" Content="{x:Static res:AppStrings.AssetEditor_ChkNumbers}" IsChecked="True" Margin="0,0,20,0" Foreground="#4B5563"/>
                                <CheckBox x:Name="GenSymbolCheck" Content="{x:Static res:AppStrings.AssetEditor_ChkSymbols}" IsChecked="True" Foreground="#4B5563"/>
                            </WrapPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Authenticator Fields -->
                    <StackPanel x:Name="AuthenticatorPanel" Spacing="12" IsVisible="False">
                        <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,10" BoxShadow="0 2 4 0 #0A000000">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblTotpSecret}"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox x:Name="TotpSecretTextBox" Grid.Column="0" PasswordChar="•" PlaceholderText="JBSWY3DPEHPK3PXP"/>
                                    <Button Grid.Column="1" Classes="outline" Content="📋" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipCopy}" Margin="10,0,0,0" Click="CopyTotpSecretButton_Click"/>
                                </Grid>
                                <CheckBox x:Name="ShowTotpSecretCheckBox" Content="{x:Static res:AppStrings.AssetEditor_ChkShowSecret}" IsCheckedChanged="ShowTotpSecretCheckBox_CheckedChanged" Foreground="#4B5563"/>
                                
                                <!-- Display generated code for convenience -->
                                <Border Background="#F3F4F6" CornerRadius="4" Padding="15" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                        <TextBlock Text="{x:Static res:AppStrings.AssetEditor_LblCurrentCode}" VerticalAlignment="Center" Foreground="#4B5563"/>
                                        <TextBlock x:Name="TotpCurrentCodeTextBlock" Text="------" FontSize="24" FontWeight="Bold" Foreground="#2563EB" VerticalAlignment="Center" FontFamily="Consolas, Monospace"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel> <!-- AuthenticatorPanel -->
                    </StackPanel> <!-- CredentialsPanel -->

                    <TabControl Margin="0,20,0,0">
                        <TabItem Header="{x:Static res:AppStrings.AssetEditor_TabGeneral}">
                            <StackPanel Spacing="10" Margin="10">
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblLoginUrl}"/>
                                <TextBox x:Name="UrlTextBox" PlaceholderText="https://..." />
                                
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblSecureNotes}"/>
                                <TextBox x:Name="NotesTextBox" AcceptsReturn="True" MinHeight="80" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhNotes}" />
                                
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblDetailedDesc}"/>
                                <TextBox x:Name="DetailedDescriptionTextBox" AcceptsReturn="True" MinHeight="80" PlaceholderText="{x:Static res:AppStrings.AssetEditor_DescWatermark}" />
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{x:Static res:AppStrings.AssetEditor_TabVars}">
                            <StackPanel Spacing="10" Margin="10">
                                <TextBlock Text="{x:Static res:AppStrings.AssetEditor_CustomVarsDesc}" Foreground="#6B7280"/>
                                
                                <Grid ColumnDefinitions="2*, 3*, 4*, 50" Margin="0,10,0,5">
                                    <TextBlock Grid.Column="0" Text="{x:Static res:AppStrings.AssetEditor_ColName}" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock Grid.Column="1" Text="{x:Static res:AppStrings.AssetEditor_ColValue}" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock Grid.Column="2" Text="{x:Static res:AppStrings.AssetEditor_ColDesc}" FontWeight="SemiBold" Foreground="#374151"/>
                                </Grid>
                                
                                <ListBox x:Name="CustomFieldsListBox" MinHeight="150" MaxHeight="300" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="contracts:CustomField">
                                            <Grid ColumnDefinitions="2*, 3*, 4*, 50" Margin="0,2">
                                                <TextBox Grid.Column="0" Text="{Binding Name}" Margin="0,0,5,0" />
                                                <TextBox Grid.Column="1" Text="{Binding Value}" Margin="0,0,5,0" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhUserPrompt}" />
                                                <TextBox Grid.Column="2" Text="{Binding Description}" Margin="0,0,5,0" />
                                                <Button Grid.Column="3" Content="❌" Foreground="Red" Classes="outline" HorizontalAlignment="Center" Click="RemoveCustomFieldButton_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <Button Classes="outline" Content="➕" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipAddVar}" Click="AddCustomFieldButton_Click" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{x:Static res:AppStrings.AssetEditor_TabAcl}">
                            <StackPanel Spacing="10" Margin="10">
                                <TextBlock Text="{x:Static res:AppStrings.AssetEditor_AclDesc}" Foreground="#6B7280"/>
                                <CheckBox x:Name="IsInheritingCheckBox" Content="{x:Static res:AppStrings.AssetEditor_AclInherit}" IsVisible="False" Foreground="#2563EB" FontWeight="SemiBold" Click="IsInheritingCheckBox_Click"/>
                                
                                <Grid ColumnDefinitions="*, Auto, 130, Auto" Margin="0,10,0,5">
                                    <TextBlock Grid.Column="0" Text="{x:Static res:AppStrings.AssetEditor_ColUser}" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock Grid.Column="2" Text="{x:Static res:AppStrings.AssetEditor_ColRole}" FontWeight="SemiBold" Foreground="#374151"/>
                                </Grid>
                                
                                <ListBox x:Name="AclsListBox" MinHeight="150" MaxHeight="300" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="local:AclGroupItemViewModel">
                                            <Grid ColumnDefinitions="Auto, *, Auto, 130, Auto" Margin="0,2">
                                                <TextBlock Grid.Column="0" Text="{Binding Icon}" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="16"/>
                                                
                                                <Grid Grid.Column="1" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding NameWithSource}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#111827" FontSize="14"/>
                                                    <TextBlock Text="{x:Static res:AppStrings.AssetEditor_Inherited}" IsVisible="{Binding IsInherited}" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,2,25,0" IsHitTestVisible="False"/>
                                                </Grid>
                                                
                                                <Button Grid.Column="2" IsVisible="False" />
                                                
                                                <ComboBox Grid.Column="3" SelectedIndex="{Binding UiPermissionIndex}" Margin="0,0,10,0" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_AclDeny}" Foreground="Red"/>
                                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_AclNone}" />
                                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_AclExec}" />
                                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_AclRead}" />
                                                    <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_AclOwner}" />
                                                </ComboBox>
                                                
                                                <Button Grid.Column="4" Content="❌" Foreground="Red" Classes="outline" HorizontalAlignment="Center" Click="RemoveAclButton_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <Button Classes="outline" Content="➕" ToolTip.Tip="Benutzer/Gruppe hinzufügen" Click="AddAclButton_Click" HorizontalAlignment="Left"/>
                                
                                <CheckBox x:Name="ApplyToChildrenCheckBox" Content="{x:Static res:AppStrings.AssetEditor_AclApplyChildren}" IsVisible="False" Foreground="#6B7280" Margin="0,10,0,0"/>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{x:Static res:AppStrings.AssetEditor_TabAttachments}">
                            <StackPanel Spacing="10" Margin="10">
                                <Button Classes="outline" Content="📎" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipAddFile}" Click="AddAttachmentButton_Click" HorizontalAlignment="Left"/>
                                <ListBox x:Name="AttachmentsListBox" MinHeight="120" MaxHeight="250" Background="#F9FAFB" CornerRadius="6" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="contracts:VaultAttachment">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="📄" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Classes="outline" Content="📥" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipDlSel}" Click="DownloadAttachmentButton_Click"/>
                                    <Button Classes="outline" Content="🗑️" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipRmSel}" Click="RemoveAttachmentButton_Click" Foreground="Red"/>
                                </StackPanel>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="{x:Static res:AppStrings.AssetEditor_TabSettings}">
                            <StackPanel Spacing="12" Margin="10">
                                <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblValidity}"/>
                                <NumericUpDown x:Name="ValidityDaysControl" Value="365" Minimum="1" Maximum="365" Width="150" HorizontalAlignment="Left" CornerRadius="4"/>
                                
                                <CheckBox x:Name="RequiresAuditLogCheckBox" Content="{x:Static res:AppStrings.AssetEditor_ChkAuditLog}" Foreground="#4B5563" ToolTip.Tip="{x:Static res:AppStrings.AssetEditor_TipAuditLog}"/>
                                
                                <Expander Header="{x:Static res:AppStrings.AssetEditor_HdrAuto}" HorizontalAlignment="Stretch" CornerRadius="4" Background="White" BorderBrush="#E5E7EB">
                                    <StackPanel Spacing="12" Margin="10">
                                        <TextBlock Classes="label" Text="{x:Static res:AppStrings.AssetEditor_LblMethod}"/>
                                        <ComboBox x:Name="LoginMethodComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" CornerRadius="4">
                                            <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_ComboAuto}" />
                                            <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_ComboOne}" />
                                            <ComboBoxItem Content="TwoStep (Username -> Next -> Password)" />
                                            <ComboBoxItem Content="{x:Static res:AppStrings.AssetEditor_ComboBasic}" />
                                        </ComboBox>
                                        <CheckBox x:Name="AutoLearnEnabledCheck" Content="{x:Static res:AppStrings.AssetEditor_ChkAutoLearn}" IsChecked="True" Foreground="#4B5563"/>
                                        
                                        <Border BorderThickness="0,1,0,0" BorderBrush="#E5E7EB" Margin="0,10,0,5" Padding="0,15,0,0">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="{x:Static res:AppStrings.AssetEditor_LblDom}" FontWeight="SemiBold" Foreground="#374151"/>
                                                <TextBox x:Name="DomUserTextBox" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhUserSel}" />
                                                <TextBox x:Name="DomPassTextBox" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhPassSel}" />
                                                <TextBox x:Name="DomNextTextBox" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhNextSel}" />
                                                <TextBox x:Name="DomSubmitTextBox" PlaceholderText="{x:Static res:AppStrings.AssetEditor_PhSubSel}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel> <!-- EditorPanel -->
            </ScrollViewer>
</Window>
