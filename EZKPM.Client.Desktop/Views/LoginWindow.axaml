<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.LoginWindow"
        Title="EZK-PM Enterprise Login"
        Width="400" Height="300"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#0F172A">
    <Border CornerRadius="8" BorderBrush="#334155" BorderThickness="1" Background="#1E293B" Padding="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" />
            <TextBlock Text="EZK-PM" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
            
            <TextBlock Text="Tresor ist gesperrt." Foreground="#94A3B8" HorizontalAlignment="Center" />
            <TextBlock Text="Wird durch Windows-Anmeldung (DPAPI) gesichert." FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
            
            <Button x:Name="UnlockButton" Content="Mit Windows-Profil entsperren" 
                    Background="#3B82F6" Foreground="White" 
                    HorizontalAlignment="Center" Padding="15,10"
                    Click="UnlockButton_Click"/>
                    
            <ProgressBar x:Name="UnlockProgress" IsIndeterminate="True" IsVisible="False" Margin="0,10,0,0" />
            
            <TextBlock x:Name="StatusText" Text="" Foreground="#10B981" HorizontalAlignment="Center" IsVisible="False" />
            
            <StackPanel x:Name="RecoveryPanel" IsVisible="False" Spacing="10" Margin="0,10,0,0">
                <TextBlock Text="⚠️ DPAPI-Fehler: Windows-Passwort wurde ggf. zurückgesetzt." Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" />
                <Button x:Name="RecoveryButton" Content="4-Augen-Recovery anfordern" 
                        Background="#EF4444" Foreground="White" 
                        HorizontalAlignment="Center" Padding="10,5"
                        Click="RecoveryButton_Click"/>
                <Button x:Name="SimulateAdminButton" Content="[Test] Als Admin freigeben" 
                        Background="#8B5CF6" Foreground="White" 
                        HorizontalAlignment="Center" Padding="10,5"
                        IsVisible="False"
                        Click="SimulateAdminButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
