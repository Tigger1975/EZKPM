<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.SplashScreenWindow"
        Title="EZKPM Loading..."
        Width="400" Height="400"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="Transparent">
    
    <Border Background="#111827" CornerRadius="20" Padding="20" BorderBrush="#1F2937" BorderThickness="1" BoxShadow="0 10 30 0 #40000000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <Image Source="avares://EZKPM.Client.Desktop/Assets/logo.png" Width="200" Height="200" />
            <TextBlock Text="Ironclad Vault (EZKPM)" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText" Text="Entschlüssele Tresor..." Foreground="#9CA3AF" FontSize="14" HorizontalAlignment="Center" />
            <ProgressBar x:Name="LoadingProgress" IsIndeterminate="True" Height="4" Width="250" Margin="0,10,0,0" CornerRadius="2" Foreground="#3B82F6" Background="#374151" />
        </StackPanel>
    </Border>
</Window>
