<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:EZKPM.Client.Desktop.Resources"
        x:Class="EZKPM.Client.Desktop.Views.CsvMappingWindow"
        Title="{x:Static res:AppStrings.CsvMapping_Title}" Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="{x:Static res:AppStrings.CsvMapping_Header}" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
        <TextBlock Text="{x:Static res:AppStrings.CsvMapping_Desc}" Foreground="#4B5563" TextWrapping="Wrap"/>
        
        <Grid ColumnDefinitions="150, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,10">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:AppStrings.CsvMapping_LblName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TitleComboBox" HorizontalAlignment="Stretch" Margin="0,5"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:AppStrings.CsvMapping_LblUser}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="UsernameComboBox" HorizontalAlignment="Stretch" Margin="0,5"/>
            
            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:AppStrings.CsvMapping_LblPass}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="PasswordComboBox" HorizontalAlignment="Stretch" Margin="0,5"/>
            
            <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static res:AppStrings.CsvMapping_LblUrl}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="UrlComboBox" HorizontalAlignment="Stretch" Margin="0,5"/>
            
            <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:AppStrings.CsvMapping_LblNotes}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="NotesComboBox" HorizontalAlignment="Stretch" Margin="0,5"/>
        </Grid>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="{x:Static res:AppStrings.CsvMapping_BtnCancel}" Click="CancelButton_Click"/>
            <Button Content="{x:Static res:AppStrings.CsvMapping_BtnImport}" Click="OkButton_Click" Background="#2563EB" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</Window>
