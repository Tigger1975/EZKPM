<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.PairingWindow"
        Title="EZKPM - Geräte-Pairing"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#1E1E1E">
    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🛡️ Ironclad Vault Setup" FontSize="24" FontWeight="Bold" Foreground="#4A90E2" HorizontalAlignment="Center"/>
            <TextBlock Text="Willkommen bei EZKPM. Ihr Gerät wird jetzt mit dem Server verbunden." Foreground="LightGray" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="15">
            <TextBlock Text="Pairing-Code (oder 'GENESIS' für ersten Admin):" Foreground="White" FontWeight="SemiBold"/>
            <TextBox x:Name="CodeTextBox" IsReadOnly="False" FontSize="18" TextAlignment="Center" Background="#2D2D2D" Foreground="#4A90E2" FontWeight="Bold"/>

            <TextBlock Text="Master-Passwort festlegen (leer lassen für Seamless SSO):" Foreground="White" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TextBox x:Name="PasswordTextBox" PasswordChar="•" FontSize="18" Watermark="Optionales Passwort" Background="#2D2D2D" Foreground="White"/>

            <TextBlock x:Name="StatusText" Text="Status: Bereit zur Registrierung..." Foreground="Yellow" TextWrapping="Wrap" Margin="0,10,0,0"/>
            <ProgressBar x:Name="ProgressIndicator" IsIndeterminate="True" IsVisible="False" Margin="0,10,0,0" Height="4"/>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="CancelButton" Content="Abbrechen" Width="100" Background="#444" Foreground="White"/>
            <Button x:Name="RegisterButton" Content="Gerät Registrieren" Width="150" Background="#4A90E2" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

    </Grid>
</Window>
