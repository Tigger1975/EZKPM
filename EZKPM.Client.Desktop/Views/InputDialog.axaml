<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.InputDialog"
        Title="Eingabe" Width="450" Height="200" WindowStartupLocation="CenterOwner" CanResize="False"
        WindowDecorations="None">
    <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
        <StackPanel Spacing="15">
            <TextBlock x:Name="MessageTextBlock" Text="Bitte geben Sie einen Wert ein:" FontWeight="SemiBold" FontSize="16" Foreground="#111827" TextWrapping="Wrap"/>
            <TextBox x:Name="InputTextBox" Height="40" CornerRadius="4" BorderBrush="#D1D5DB" VerticalContentAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
                <Button Content="Abbrechen" Background="Transparent" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="15,8" Click="CancelButton_Click"/>
                <Button Content="OK" Background="#2563EB" Foreground="White" CornerRadius="6" Padding="20,8" Click="OkButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
