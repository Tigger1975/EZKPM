<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:EZKPM.Client.Desktop.Resources"
        x:Class="EZKPM.Client.Desktop.Views.PasswordPromptDialog"
        Title="{x:Static res:AppStrings.PwdPrompt_Title}" Width="450" Height="250" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock x:Name="MessageTextBlock" Text="{x:Static res:AppStrings.PwdPrompt_Desc}" TextWrapping="Wrap" />
        <TextBox x:Name="PasswordTextBox" PasswordChar="•" PlaceholderText="{x:Static res:AppStrings.PwdPrompt_Watermark}" />
        
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="{x:Static res:AppStrings.PwdPrompt_BtnSelectKey}" Click="SelectKeyFile_Click" />
            <TextBlock x:Name="KeyFilePathTextBlock" VerticalAlignment="Center" FontStyle="Italic" Text="{x:Static res:AppStrings.PwdPrompt_NoFile}" TextTrimming="CharacterEllipsis" MaxWidth="200" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{x:Static res:AppStrings.PwdPrompt_BtnOk}" Click="OkButton_Click" Background="#3B82F6" Foreground="White" />
            <Button Content="{x:Static res:AppStrings.PwdPrompt_BtnCancel}" Click="CancelButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
