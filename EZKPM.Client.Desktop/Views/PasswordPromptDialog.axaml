<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.PasswordPromptDialog"
        Title="Passwort / Key-Datei erforderlich" Width="450" Height="250" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock x:Name="MessageTextBlock" Text="Bitte geben Sie das Master-Passwort und/oder eine Key-Datei für die KeePass-Datenbank ein:" TextWrapping="Wrap" />
        <TextBox x:Name="PasswordTextBox" PasswordChar="•" Watermark="Master-Passwort" />
        
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Key-Datei auswählen" Click="SelectKeyFile_Click" />
            <TextBlock x:Name="KeyFilePathTextBlock" VerticalAlignment="Center" FontStyle="Italic" Text="Keine Datei ausgewählt" TextTrimming="CharacterEllipsis" MaxWidth="200" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Click="OkButton_Click" Background="#3B82F6" Foreground="White" />
            <Button Content="Abbrechen" Click="CancelButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
