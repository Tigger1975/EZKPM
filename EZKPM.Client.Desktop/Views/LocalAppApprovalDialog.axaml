<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.LocalAppApprovalDialog"
        Title="Zugriffsanfrage bestätigen"
        Width="450" MinHeight="400" SizeToContent="Height"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        RequestedThemeVariant="Dark"
        Topmost="True">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Styles>

    <Border Background="#111827" CornerRadius="20" Padding="30" BorderBrush="#1F2937" BorderThickness="1" BoxShadow="0 10 30 0 #40000000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <!-- LOGO & HEADER -->
            <Image Source="avares://EZKPM.Client.Desktop/Assets/logo.png" Width="100" Height="100" />
            <TextBlock Text="Lokale Sicherheitsabfrage" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
            
            <Border Background="#1F2937" CornerRadius="10" Padding="15" Margin="0,10">
                <TextBlock x:Name="MessageText" 
                           Text="Eine lokale Applikation fordert Zugriff auf Anmeldedaten an." 
                           Foreground="#9CA3AF" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center" 
                           FontSize="14"/>
            </Border>

            <CheckBox x:Name="TrustCheckBox" 
                      Content="Dieser Applikation dauerhaft vertrauen (Prüft Signatur/Hash)" 
                      Foreground="White" 
                      HorizontalAlignment="Center" />

            <TextBlock x:Name="WarningText" 
                       Foreground="#EF4444" 
                       FontSize="13" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center"
                       IsVisible="False" />

            <TextBlock Text="Wenn Sie dieser Applikation nicht vertrauen, lehnen Sie die Anfrage ab." 
                       Foreground="#EF4444" 
                       FontSize="12" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center"/>

            <StackPanel Spacing="10" Margin="0,10,0,0" HorizontalAlignment="Stretch">
                <Button x:Name="ApproveButton" 
                        Content="Zugriff zulassen" 
                        Click="ApproveButton_Click" 
                        Background="#10B981" 
                        Foreground="White" 
                        Padding="20,12"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button x:Name="DenyButton" 
                        Content="Anfrage ablehnen" 
                        Click="DenyButton_Click" 
                        Background="Transparent" 
                        Foreground="#9CA3AF" 
                        BorderBrush="#374151"
                        BorderThickness="1"
                        Padding="20,12"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
