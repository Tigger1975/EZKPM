<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:EZKPM.Client.Desktop.Resources"
        x:Class="EZKPM.Client.Desktop.Views.ServerConfigWindow"
        Title="{x:Static res:AppStrings.ServerConfig_Title}"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        ExtendClientAreaToDecorationsHint="True"
        CanResize="False"
        RequestedThemeVariant="Dark">

    <Border BorderBrush="#1F2937" BorderThickness="1" CornerRadius="20" Background="#111827" Margin="10" BoxShadow="0 10 30 0 #000000">
        <StackPanel Margin="30" Spacing="20">
            <TextBlock Text="{x:Static res:AppStrings.ServerConfig_Header}" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" />

            <TextBlock Text="{x:Static res:AppStrings.ServerConfig_Desc}" 
                       Foreground="#9CA3AF" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center" />

            <TextBox x:Name="UrlTextBox" 
                     PlaceholderText="{x:Static res:AppStrings.ServerConfig_UrlWatermark}" 
                     Background="#1F2937" 
                     Foreground="White" 
                     BorderBrush="#374151" 
                     Padding="12" />

            <CheckBox x:Name="AutostartCheckBox" 
                      Content="{x:Static res:AppStrings.ServerConfig_AutoStart}" 
                      Foreground="White" 
                      Margin="0,10,0,0" />

            <TextBlock x:Name="StatusText" 
                       Foreground="Red" 
                       IsVisible="False" 
                       TextWrapping="Wrap" 
                       HorizontalAlignment="Center" />
            
            <Border Background="#1F2937" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="App-Version" Foreground="#9CA3AF" FontSize="11" />
                        <TextBlock x:Name="VersionText" Text="1.0.0.0" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="CheckUpdateButton" 
                            Content="Nach Updates suchen" 
                            Background="#4B5563" 
                            Foreground="White" 
                            CornerRadius="4" 
                            Padding="10,5" 
                            VerticalAlignment="Center"
                            Click="CheckUpdateButton_Click" />
                </Grid>
            </Border>
            
            <ProgressBar x:Name="TestProgress" 
                         IsIndeterminate="True" 
                         IsVisible="False" 
                         Height="4" 
                         Foreground="#3B82F6" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,0">
                <Button x:Name="CancelButton" 
                        Content="{x:Static res:AppStrings.ServerConfig_BtnCancel}" 
                        Click="CancelButton_Click" 
                        Background="Transparent" 
                        Foreground="#9CA3AF" 
                        Padding="20,10" />
                <Button x:Name="SaveButton" 
                        Content="{x:Static res:AppStrings.ServerConfig_BtnSave}" 
                        Click="SaveButton_Click" 
                        Background="#3B82F6" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        Padding="20,10" 
                        CornerRadius="8" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
