<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EZKPM.Client.Desktop.Views.AdminDashboardWindow"
        Title="Admin Dashboard" Width="800" Height="600"
        WindowStartupLocation="CenterOwner" Background="#F9FAFB">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="#1E293B" Padding="20">
            <StackPanel>
                <TextBlock Text="🛡️ Admin Dashboard" FontSize="24" FontWeight="Bold" Foreground="White" />
                <TextBlock x:Name="BootstrapWarningText" Text="⚠️ BOOTSTRAP MODUS AKTIV: Es gibt keine Administratoren. Sie können sich selbst als Admin hinzufügen." Foreground="#FACC15" IsVisible="False" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Admin-Verwaltung">
                <Grid RowDefinitions="Auto, Auto, Auto, *" Margin="10">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                        <TextBlock Text="User SID oder Name suchen:" VerticalAlignment="Center"/>
                        <TextBox x:Name="SearchAdminTextBox" Width="200" Watermark="Suche im AD..."/>
                        <Button Content="Suchen" Click="SearchAdminButton_Click" Classes="primary" Background="#3B82F6" Foreground="White" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="Ausgewählter Benutzer:" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="SelectedAdminText" Text="Keine Auswahl" FontSize="18" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Als Admin hinzufügen" Click="MakeAdminButton_Click" Background="#10B981" Foreground="White" />
                        <Button Content="Admin-Rechte entziehen" Click="RemoveAdminButton_Click" Background="#EF4444" Foreground="White" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="10" Margin="0,20,0,0">
                        <TextBlock Text="Aktuelle Administratoren" FontWeight="Bold"/>
                        <TextBlock Text="Da der Server nach dem Zero-Knowledge-Prinzip nur gehashte SIDs speichert, muss der Client diese Liste über das Active Directory auflösen." Foreground="Gray" TextWrapping="Wrap" FontSize="12"/>
                        <ListBox x:Name="CurrentAdminsList" Height="100" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:CompileBindings="False">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Admins aus AD auflösen (kann dauern)" Click="ResolveAdminsButton_Click" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <TabItem Header="Recovery-Verwaltung">
                <Grid RowDefinitions="Auto, *, Auto" Margin="10">
                    <TextBlock Grid.Row="0" Text="Offene Recovery-Anfragen" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <ListBox x:Name="PendingRecoveryList" Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <StackPanel Spacing="5" Margin="5">
                                    <TextBlock Text="{Binding AdSid, StringFormat='Ziel-User SID: {0}'}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding RequestedAt, StringFormat='Angefragt am: {0:g}'}"/>
                                    <TextBlock Text="{Binding ProvidedShares.Count, StringFormat='Freigaben: {0} / 2'}" Foreground="Green"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Aktualisieren" Click="RefreshRecoveryButton_Click" />
                        <Button Content="Freigeben (Share senden)" Click="ApproveRecoveryButton_Click" Background="#3B82F6" Foreground="White" />
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <TabItem Header="Fremd-Recovery initiieren">
                <Grid RowDefinitions="Auto, *, Auto" Margin="10">
                    <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                        <TextBlock Text="Recovery für anderen User anfordern (z.B. nach Austritt)" FontWeight="Bold"/>
                        <TextBlock Text="Hinweis: Sie benötigen die Freigabe von 2 weiteren Administratoren." Foreground="Gray" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <TextBlock Text="Ziel-User SID:" VerticalAlignment="Center"/>
                            <TextBox x:Name="TargetUserSidTextBox" Width="200" Watermark="S-1-5-21-..."/>
                            <Button Content="Suchen..." Click="SearchDisabledUserButton_Click" />
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Grid.Row="2" Content="Recovery anfordern" Click="InitiateRecoveryButton_Click" HorizontalAlignment="Right" Background="#F59E0B" Foreground="White" />
                </Grid>
        </TabItem>

            <TabItem Header="Identitäten (Mapping)">
                <Grid RowDefinitions="Auto, *, Auto" Margin="10">
                    <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                        <TextBlock Text="Separation of Duties (6-Augen-Prinzip sichern)" FontWeight="Bold"/>
                        <TextBlock Text="Verknüpfen Sie hier den administrativen AD-Account (z.B. adm-kh) mit dem Standard-Account (z.B. kh) einer Person. Dadurch wird sichergestellt, dass das 6-Augen-Prinzip nicht durch Mehrfach-Accounts derselben Person untergraben werden kann." Foreground="Gray" TextWrapping="Wrap"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,15,0,0">
                            <TextBlock Text="Quell-Account (Wird verknüpft):" Width="200" VerticalAlignment="Center"/>
                            <Button Content="Suchen..." Click="PickSourcePersonButton_Click" />
                            <TextBlock x:Name="SourcePersonText" Text="Keine Auswahl" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#3B82F6"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <TextBlock Text="Ziel-Account (Haupt-Identität):" Width="200" VerticalAlignment="Center"/>
                            <Button Content="Suchen..." Click="PickTargetPersonButton_Click" />
                            <TextBlock x:Name="TargetPersonText" Text="Keine Auswahl" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#10B981"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Grid.Row="2" Content="Accounts zu einer Person zusammenführen" Click="LinkPersonsButton_Click" HorizontalAlignment="Right" Background="#8B5CF6" Foreground="White" />
                </Grid>
            </TabItem>
            <TabItem Header="Sicherheitswarnungen">
                <Grid RowDefinitions="Auto, *, Auto" Margin="10">
                    <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                        <TextBlock Text="Vulnerability Scanner Berichte" FontWeight="Bold"/>
                        <TextBlock Text="Diese Liste zeigt alle offenen Sicherheitsprobleme (CVEs/Exploits) an, die von den Admin-Clients in den verwendeten Anwendungspaketen gefunden wurden." Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <ListBox x:Name="SecurityAlertsList" Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <StackPanel Spacing="5" Margin="5">
                                    <TextBlock Text="{Binding PackageName}" FontWeight="Bold" Foreground="#EF4444" />
                                    <TextBlock Text="{Binding Version}" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Details}" IsReadOnly="True" BorderThickness="0" Background="Transparent" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding CreatedAt}" Foreground="Gray" FontSize="12" />
                                        <Button Content="Als erledigt markieren" Tag="{Binding Id}" Click="ResolveAlertButton_Click" Background="#10B981" Foreground="White" Padding="5,2" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Sicherheits-Scan jetzt erzwingen" Click="ForceScanButton_Click" Background="#F59E0B" Foreground="White" />
                        <Button Content="Liste aktualisieren" Click="RefreshAlertsButton_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
