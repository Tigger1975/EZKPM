<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:EZKPM.Client.Desktop.Resources"
        x:Class="EZKPM.Client.Desktop.Views.StartupWindow"
        Title="{x:Static res:AppStrings.Startup_Title}"
        Width="450" MinHeight="400" SizeToContent="Height"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        RequestedThemeVariant="Dark">
    
    <Border Background="#111827" CornerRadius="20" Padding="30" BorderBrush="#1F2937" BorderThickness="1" BoxShadow="0 10 30 0 #40000000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <Image Source="avares://EZKPM.Client.Desktop/Assets/logo.png" Width="240" Height="240" />
            <TextBlock Text="Ironclad Vault (EZKPM)" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
            
            <!-- SERVER CONFIG PANEL -->
            <StackPanel x:Name="ServerConfigPanel" IsVisible="False" Spacing="15">
                <TextBlock Text="{x:Static res:AppStrings.ServerConfig_Header}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Static res:AppStrings.ServerConfig_Desc}" Foreground="#9CA3AF" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                
                <TextBox x:Name="UrlTextBox" PlaceholderText="{x:Static res:AppStrings.ServerConfig_UrlWatermark}" Background="#1F2937" Foreground="White" BorderBrush="#374151" Padding="12" />
                <TextBlock x:Name="ConfigStatusText" Foreground="Red" IsVisible="False" TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="12" />
                <ProgressBar x:Name="ConfigTestProgress" IsIndeterminate="True" IsVisible="False" Height="4" Foreground="#3B82F6" />
                
                <Button x:Name="SaveConfigButton" Content="{x:Static res:AppStrings.ServerConfig_BtnSave}" Click="SaveConfigButton_Click" Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
            </StackPanel>

            <!-- AUTH PANEL -->
            <StackPanel x:Name="AuthPanel" IsVisible="False" Spacing="15">
                <TextBlock Text="{x:Static res:AppStrings.Startup_VaultLocked}" Foreground="#94A3B8" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Static res:AppStrings.Startup_UnlockDesc}" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                
                <Button x:Name="UnlockButton" Content="{x:Static res:AppStrings.Startup_BtnUnlock}" 
                        Background="#3B82F6" Foreground="White" 
                        HorizontalAlignment="Center" Padding="15,10"
                        Click="UnlockButton_Click"/>
                        
                <ProgressBar x:Name="UnlockProgress" IsIndeterminate="True" Height="4" Width="250" Margin="0,10,0,0" CornerRadius="2" Foreground="#3B82F6" Background="#374151" IsVisible="False" />
                
                <TextBlock x:Name="StatusText" Text="" Foreground="#10B981" HorizontalAlignment="Center" IsVisible="False" />
                
                <StackPanel x:Name="SetupPanel" IsVisible="False" Spacing="10" Margin="0,10,0,0">
                    <TextBlock Text="{x:Static res:AppStrings.Startup_NewDevice}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Static res:AppStrings.Startup_SecretKeyDesc}" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBox x:Name="SecretKeyTextBox" PlaceholderText="EZ-XXXXX-XXXXX-XXXXX-XXXXX-XXXXXX" PasswordChar="•" HorizontalAlignment="Stretch"/>
                    <Button x:Name="SetupDeviceButton" Content="{x:Static res:AppStrings.Startup_BtnSetupDevice}" 
                            Background="#10B981" Foreground="White" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="15,10"
                            Click="SetupDeviceButton_Click"/>
                    <Button x:Name="CreateVaultButton" Content="{x:Static res:AppStrings.Startup_BtnCreateVault}" 
                            Background="Transparent" Foreground="#3B82F6" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10,5"
                            Click="CreateVaultButton_Click"/>
                </StackPanel>
                
                <StackPanel x:Name="MigrationPanel" IsVisible="False" Spacing="10" Margin="0,10,0,0">
                    <TextBlock Text="{x:Static res:AppStrings.Startup_MigrateTitle}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Static res:AppStrings.Startup_MigrateDesc}" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBox x:Name="LegacyPasswordTextBox" PlaceholderText="Legacy Master-Password" PasswordChar="•" HorizontalAlignment="Stretch"/>
                    <Button x:Name="MigrateButton" Content="{x:Static res:AppStrings.Startup_BtnMigrate}" 
                            Background="#8B5CF6" Foreground="White" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="15,10"
                            Click="MigrateButton_Click"/>
                </StackPanel>
                
                <StackPanel x:Name="RecoveryPanel" IsVisible="False" Spacing="10" Margin="0,10,0,0">
                    <TextBlock Text="{x:Static res:AppStrings.Startup_RecoveryError}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" />
                    <Button x:Name="RecoveryButton" Content="{x:Static res:AppStrings.Startup_BtnRecovery}" 
                            Background="#EF4444" Foreground="White" 
                            HorizontalAlignment="Center" Padding="10,5"
                            Click="RecoveryButton_Click"/>
                    <Button x:Name="SimulateAdminButton" Content="[Test] Admin Approve" 
                            Background="#8B5CF6" Foreground="White" 
                            HorizontalAlignment="Center" Padding="10,5"
                            IsVisible="False"
                            Click="SimulateAdminButton_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- SPLASH PANEL -->
            <StackPanel x:Name="SplashPanel" IsVisible="False" Spacing="15">
                <TextBlock x:Name="SplashStatusText" Text="{x:Static res:AppStrings.Startup_SplashDecr}" Foreground="#9CA3AF" FontSize="14" HorizontalAlignment="Center" />
                <ProgressBar x:Name="SplashProgress" IsIndeterminate="True" Height="4" Width="250" Margin="0,10,0,0" CornerRadius="2" Foreground="#3B82F6" Background="#374151" />
                <Button x:Name="ResetClientButton" Content="Verbindung trennen / Reset" IsVisible="False" Background="#EF4444" Foreground="White" HorizontalAlignment="Center" Padding="10,5" Click="ResetClientButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
